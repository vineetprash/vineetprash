---
import '../styles/global.css';
// Self-hosted Poppins — latin subset only (no Devanagari/Latin-ext bloat)
import '@fontsource/poppins/latin-400.css';
import '@fontsource/poppins/latin-500.css';
import '@fontsource/poppins/latin-600.css';
import '@fontsource/poppins/latin-700.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Vineet Prashant - Software Engineer',
  description = 'Software engineer focused on intelligent systems, developer tooling, scalable & secure architecture, and occasional game development.',
  image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://vineetprash.vercel.app');
const ogImage = new URL(image, Astro.site ?? 'https://vineetprash.vercel.app');

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': canonicalURL.origin + '/#person',
      name: 'Vineet Prashant',
      url: canonicalURL.origin,
      sameAs: [
        'https://github.com/vineetprash',
        'https://linkedin.com/in/vineetprash',
      ],
      jobTitle: 'Software Engineer',
      description,
    },
    {
      '@type': 'WebSite',
      '@id': canonicalURL.origin + '/#website',
      url: canonicalURL.origin,
      name: 'Vineet Prashant',
      author: { '@id': canonicalURL.origin + '/#person' },
    },
  ],
};
---

<html lang="en" class="scroll-smooth dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Vineet Prashant" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Vineet Prashant" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Theme color (browser chrome on mobile) -->
    <meta name="theme-color" content="#000000" />

    <!-- JSON-LD structured data -->
    <!-- <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} /> -->

    <style>
      :root {
        --font-poppins: 'Poppins', ui-sans-serif, system-ui, sans-serif;
      }
      body {
        font-family: var(--font-poppins);
      }
    </style>
  </head>
  <body class="antialiased scroll-smooth">
    <slot />
  </body>
</html>
