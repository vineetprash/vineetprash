---
// Pure CSS aurora — GPU-composited transforms + border-radius morphing
---

<div class="aurora" aria-hidden="true">
  <div class="band band-1"></div>
  <div class="band band-2"></div>
  <div class="band band-3"></div>
  <div class="band band-4"></div>
</div>

<style>
  .aurora {
    position: absolute;
    top: -7%;
    left: 0;
    right: 0;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .band {
    position: absolute;
    width: 240%;
    left: -20%;
    height: 6vh;
    will-change: transform;
    mix-blend-mode: screen;
    filter: blur(30px);
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(62, 48, 5, 0.45) 35%,
      rgba(62, 48, 5, 0.45) 65%,
      transparent 100%
    );
  }

  /* Stack bands close together, each offset ~1.5vh apart */
  .band-1 { top: 12%;  opacity: 0.65; animation: wave 9s  ease-in-out infinite;        }
  .band-2 { top: 14%;  opacity: 0.5;  animation: wave 9s  ease-in-out infinite -2.2s;  }
  .band-3 { top: 16%;  opacity: 0.4;  animation: wave 9s  ease-in-out infinite -4.5s;  }
  .band-4 { top: 18%;  opacity: 0.3;  animation: wave 9s  ease-in-out infinite -6.8s;  }

  /* Single shared wave keyframe — all bands use it, phase-shifted via negative delay */
  @keyframes wave {
    0%   { transform: translateY(0)    translateX(0)    scaleY(1);    border-radius: 40% 60% 55% 45% / 40% 40% 60% 60%; }
    25%  { transform: translateY(2.5vh) translateX(3vw)  scaleY(1.1);  border-radius: 55% 45% 45% 55% / 55% 35% 65% 45%; }
    50%  { transform: translateY(5vh)   translateX(-2vw) scaleY(0.92); border-radius: 45% 55% 60% 40% / 45% 55% 45% 55%; }
    75%  { transform: translateY(2vh)   translateX(4vw)  scaleY(1.08); border-radius: 60% 40% 50% 50% / 60% 40% 55% 45%; }
    100% { transform: translateY(0)    translateX(0)    scaleY(1);    border-radius: 40% 60% 55% 45% / 40% 40% 60% 60%; }
  }
</style>
